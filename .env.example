# ============================================
# FIREBASE — Authentification (côté client)
# ============================================
# À récupérer dans : Firebase Console → Paramètres du projet → Général → Vos applications
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================
# FIREBASE ADMIN — Vérification des tokens (côté serveur)
# ============================================
# À récupérer dans : Firebase Console → Paramètres du projet → Comptes de service
# → Générer une nouvelle clé privée → télécharger le JSON → copier les 3 champs
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ============================================
# IA — Gemini (Google) ET/OU Mistral
# ============================================
# Au moins UNE des deux doit être configurée.
GEMINI_API_KEY=
MISTRAL_API_KEY=

# ============================================
# FRANCE TRAVAIL — Recherche d'offres (optionnel)
# ============================================
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# ============================================
# APP
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# RESEND — Envoi des emails de candidatures spontanées (Lot 5)
# ============================================
# Créer un compte sur resend.com, vérifier un domaine expéditeur,
# puis générer une clé API.
RESEND_API_KEY=
# Format : "Prénom Nom <adresse@tondomaine.fr>"
RESEND_FROM_EMAIL=

# ============================================
# SÉCURITÉ — CORS de l'inscription bêta
# ============================================
# Origines autorisées à appeler /api/beta-signup (séparées par des virgules).
# Inclure la landing Next.js ET la page HTML autonome si elle est hébergée
# ailleurs. À défaut, on retombe sur NEXT_PUBLIC_SITE_URL.
ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# SÉCURITÉ — Limitation de débit (par utilisateur)
# ============================================
# Plafonds d'appels IA et de recherches d'offres. Valeurs par défaut entre ().
AI_RATE_PER_MINUTE=15
AI_RATE_PER_DAY=200
FT_RATE_PER_MINUTE=20
FT_RATE_PER_DAY=300
# Ciblage entreprises La Bonne Boîte v2
LBB_RATE_PER_MINUTE=5
LBB_RATE_PER_DAY=50
# Résolution de contacts (DNS + Annuaire des Entreprises)
CR_RATE_PER_MINUTE=5
CR_RATE_PER_DAY=30
# Génération de campagne (2 appels IA lourds par campagne)
CAMPAIGN_RATE_PER_MINUTE=2
CAMPAIGN_RATE_PER_DAY=5
# Envoi des emails de candidatures spontanées
SEND_RATE_PER_MINUTE=1
SEND_RATE_PER_DAY=3
SEND_DAILY_MAX=5
SEND_DELAY_MIN_MS=2000
SEND_DELAY_MAX_MS=5000

# Inscription bêta : plafonds par adresse IP (anti-spam de l'endpoint public).
BETA_SIGNUP_IP_PER_MINUTE=5
BETA_SIGNUP_IP_PER_DAY=20

# RGPD : durée de conservation des inscriptions bêta, en jours (purge via TTL
# Firestore sur le champ expireAt — voir RGPD-RETENTION.md).
BETA_SIGNUP_RETENTION_DAYS=180
